<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

<changeSet id="6" author="team">

    <createTable tableName="mark">

        <column name="id" type="INT" autoIncrement="true">
            <constraints primaryKey="true"/>
        </column>

        <column name="mark" type="INT"/>

        <column name="feedback" type="VARCHAR(255)"/>

        <column name="answer_id" type="INT"/>

        <column name="createDateTime" type="TIMESTAMP"/>

        <column name="updateDateTime" type="TIMESTAMP"/>

    </createTable>

    <addForeignKeyConstraint
            baseTableName="mark"
            baseColumnNames="answer_id"
            referencedTableName="answer"
            referencedColumnNames="id"
            constraintName="fk_mark_amswer"/>

</changeSet>
</databaseChangeLog>